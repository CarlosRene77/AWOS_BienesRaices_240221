extends ../layout/index

block contenido
    div.min-h-screen.bg-white.flex.items-center.justify-center.p-4
        div.max-w-md.w-full
            //- Logo y título
            div.text-center.mb-10
                div.inline-block.p-4.bg-gradient-to-r.from-indigo-50.to-purple-50.rounded-2xl.mb-6
                    svg.h-12.w-12.text-indigo-600.mx-auto(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6")
                h1.text-4xl.font-bold.text-gray-900 Bienes
                    span.font-light.text-indigo-600  Raíces
                p.text-gray-500.mt-3.text-lg Accede a tu cuenta

            //- Tarjeta principal
            div.bg-white.rounded-2xl.shadow-xl.p-8.border.border-gray-100
                form.space-y-6
                    //- Campo email
                    div
                        label.block.text-sm.font-medium.text-gray-700.mb-2(for="correoUsuario") Correo electrónico
                        div.relative
                            span.absolute.inset-y-0.left-0.pl-3.flex.items-center.text-gray-400
                                svg.h-5.w-5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207")
                            input#correoUsuario.w-full.pl-10.pr-4.py-3.border.border-gray-200.rounded-xl(class="focus:border-indigo-300 focus:ring-4 focus:ring-indigo-50 focus:outline-none transition-all" placeholder="tu@email.com" name="correoUsuario" type="email")
                    
                    //- Campo contraseña
                    div
                        label.block.text-sm.font-medium.text-gray-700.mb-2(for="passwordUsuario") Contraseña
                        div.relative
                            span.absolute.inset-y-0.left-0.pl-3.flex.items-center.text-gray-400
                                svg.h-5.w-5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z")
                            input#passwordUsuario.w-full.pl-10.pr-4.py-3.border.border-gray-200.rounded-xl(class="focus:border-indigo-300 focus:ring-4 focus:ring-indigo-50 focus:outline-none transition-all" placeholder="••••••••" name="passwordUsuario" type="password")
                    
                    //- Mostrar contraseña y olvidé
                    div.flex.items-center.justify-between
                        label.flex.items-center.cursor-pointer
                            input#verP1(type="checkbox" class="sr-only" onclick="document.getElementById('passwordUsuario').type = this.checked ? 'text' : 'password'")
                            span.w-5.h-5.border.border-gray-300.rounded-md.flex.items-center.justify-center.mr-2(class="peer-checked:bg-indigo-600 peer-checked:border-indigo-600")
                                svg.h-3.w-3.text-white(fill="none" stroke="currentColor" viewBox="0 0 24 24" class="hidden peer-checked:block")
                                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7")
                            span.text-sm.text-gray-600 Mostrar contraseña
                        
                        a.text-sm.font-medium.text-indigo-600(class="hover:text-indigo-700" href="/auth/recuperacionPassword") ¿Olvidaste tu contraseña?

                    //- Botón submit
                    button.w-full.bg-gradient-to-r.from-indigo-600.to-purple-600.text-white.font-semibold.py-3.px-4.rounded-xl.transition-all.duration-200(class="hover:from-indigo-700 hover:to-purple-700 hover:shadow-lg hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" type="submit")
                        | Iniciar Sesión
                    
                    //- Separador
                    div.relative.my-6
                        div.absolute.inset-0.flex.items-center
                            div.w-full.border-t.border-gray-200
                        div.relative.flex.justify-center.text-sm
                            span.px-4.bg-white.text-gray-400 ¿Nuevo en Bienes Raíces?
                    
                    //- Link registro
                    a.block.text-center.text-gray-600.bg-gray-50.py-3.px-4.rounded-xl.font-medium.border.border-gray-200(class="hover:bg-gray-100 hover:border-gray-300 transition-all" href="/auth/registro")
                        | Crear una cuenta nueva