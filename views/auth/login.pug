extends ../layout/index

block contenido
    div(class="min-h-screen bg-gray-50 flex items-center justify-center p-4")
        div(class="max-w-md w-full")
            
            div(class="text-center mb-8")
                div(class="inline-block p-3 bg-indigo-100 rounded-full mb-4")
                    svg(class="h-8 w-8 text-indigo-600 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6")

                h1(class="text-3xl font-bold text-gray-900")
                    | Bienes 
                    span(class="font-light text-indigo-600") Raíces

                p(class="text-gray-500 mt-2 text-base") Accede a tu cuenta

            // CONTENEDOR DE MENSAJES CON TEMPORIZADOR
            if errores
                div#mensajes-container.max-w-md.mx-auto.my-6.space-y-2
                    each error in errores
                        div.mensaje-error.relative.bg-red-50.border-l-4.border-red-500.text-red-700.p-4.rounded-r-lg.shadow-md.transform.transition-all.duration-500(class="hover:shadow-lg" role="alert" data-duracion="5000")
                            div.flex.items-center
                                div.flex-shrink-0
                                    svg.h-5.w-5.text-red-500(fill="currentColor" viewBox="0 0 20 20")
                                        path(fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd")
                                div.ml-3.flex-1
                                    p.text-sm.font-medium= error.msg
                                div.flex-shrink-0.ml-2
                                    button.cerrar-mensaje.text-red-500(class="hover:text-red-700 transition-colors duration-200")
                                        svg.h-4.w-4(fill="currentColor" viewBox="0 0 20 20")
                                            path(fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd")
                            // Barra de progreso
                            div.barra-progreso.absolute.bottom-0.left-0.h-1.bg-red-500.rounded-b-lg(style="width: 100%; transition: width 5s linear;")

            div(class="bg-white rounded-lg shadow-lg p-6 border border-gray-100")
                form.space-y-5(method="POST" action="/auth/login" novalidate)
                    input(type="hidden" name="_csrf" value=csrfToken)
                    
                    div
                        label(for="correoUsuario" class="block text-sm font-medium text-gray-700 mb-1") Correo electrónico
                        input#correoUsuario(
                            type="email"
                            name="correoUsuario"
                            placeholder="tu@email.com"
                            required
                            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-transparent"
                        )

                    div
                        label(for="passwordUsuario" class="block text-sm font-medium text-gray-700 mb-1") Contraseña
                        div(class="relative")
                            input#passwordUsuario(
                                type="password"
                                name="passwordUsuario"
                                placeholder="••••••••"
                                required
                                class="w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-transparent"
                            )

                            button(
                                type="button"
                                onclick="togglePassword()"
                                class="absolute inset-y-0 right-0 flex items-center pr-3 focus:outline-none"
                                aria-label="Mostrar u ocultar contraseña"
                            )
                                svg#eyeIcon(
                                    class="h-5 w-5 text-gray-400 transition-all duration-300"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                )
                                    path(
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                                    )
                                    path(
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                                    )
                                    line#eyeSlash(
                                        x1="3"
                                        y1="3"
                                        x2="21"
                                        y2="21"
                                        stroke-width="2"
                                        class="opacity-0 translate-x-2 transition-all duration-300"
                                    )

                    div(class="flex items-center justify-between")
                        a(href="/auth/recuperacionPassword" class="text-sm text-indigo-600 hover:text-indigo-800 hover:underline transition") ¿Olvidaste tu contraseña?

                    button(
                        type="submit"
                        class="w-full bg-indigo-600 text-white py-2 px-4 rounded-lg font-medium hover:bg-indigo-700 transition focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
                    )
                        | Iniciar Sesión

                    div(class="relative my-4")
                        div(class="absolute inset-0 flex items-center")
                            div(class="w-full border-t border-gray-200")
                        div(class="relative flex justify-center text-xs")
                            span(class="px-2 bg-white text-gray-400") O

                    a(
                        href="/auth/facebook"
                        class="w-full flex items-center justify-center gap-3 bg-blue-600 text-white py-2 px-4 rounded-lg font-medium hover:bg-blue-700 transition focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 mb-3"
                    )
                        svg(class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24")
                            path(d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073c0 6.019 4.388 10.999 10.125 11.927v-8.437H7.078v-3.49h3.047V9.797c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953h-1.514c-1.492 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.072 24 18.092 24 12.073")
                        | Continuar con Facebook

                    a(
                        href="/auth/google"
                        class="w-full flex items-center justify-center gap-3 bg-white text-gray-700 border border-gray-300 py-2 px-4 rounded-lg font-medium hover:bg-gray-50 transition focus:outline-none focus:ring-2 focus:ring-gray-300 focus:ring-offset-2 shadow-sm mb-3"
                    )
                        svg(class="h-5 w-5" viewBox="0 0 24 24")
                            path(
                                fill="#4285F4"
                                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                            )
                            path(
                                fill="#34A853"
                                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                            )
                            path(
                                fill="#FBBC05"
                                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                            )
                            path(
                                fill="#EA4335"
                                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                            )
                        | Continuar con Google

                    a(
                        href="/auth/registro"
                        class="block text-center text-sm text-gray-600 bg-gray-100 py-2 px-4 rounded-lg border border-gray-200 mt-4 hover:bg-gray-200 transition focus:outline-none focus:ring-2 focus:ring-gray-300"
                    )
                        | Crear una cuenta nueva

    script.
        function togglePassword() {
            const input = document.getElementById('passwordUsuario');
            const slash = document.getElementById('eyeSlash');

            if (input.type === 'password') {
                input.type = 'text';
                slash.classList.remove('opacity-0', 'translate-x-2');
                slash.classList.add('opacity-100', 'translate-x-0');
            } else {
                input.type = 'password';
                slash.classList.remove('opacity-100', 'translate-x-0');
                slash.classList.add('opacity-0', 'translate-x-2');
            }
        }

    script.
        // Función para manejar los mensajes con temporizador
        document.addEventListener('DOMContentLoaded', function() {
            const mensajes = document.querySelectorAll('.mensaje-error');
            
            mensajes.forEach(mensaje => {
                const duracion = parseInt(mensaje.dataset.duracion) || 5000;
                const barraProgreso = mensaje.querySelector('.barra-progreso');
                const botonCerrar = mensaje.querySelector('.cerrar-mensaje');
                
                // Estado para controlar el temporizador
                let temporizador;
                let tiempoRestante = duracion;
                let inicioPausa;
                
                // Función para iniciar el temporizador
                function iniciarTemporizador() {
                    temporizador = setTimeout(() => {
                        cerrarMensaje(mensaje);
                    }, tiempoRestante);
                }
                
                // Función para pausar el temporizador
                function pausarTemporizador() {
                    clearTimeout(temporizador);
                    inicioPausa = Date.now();
                    
                    // Pausar la barra de progreso
                    if (barraProgreso) {
                        const anchoActual = window.getComputedStyle(barraProgreso).width;
                        barraProgreso.style.transition = 'none';
                        barraProgreso.style.width = anchoActual;
                    }
                }
                
                // Función para reanudar el temporizador
                function reanudarTemporizador() {
                    if (inicioPausa) {
                        const tiempoTranscurrido = Date.now() - inicioPausa;
                        tiempoRestante = Math.max(0, tiempoRestante - tiempoTranscurrido);
                        
                        if (tiempoRestante > 0) {
                            if (barraProgreso) {
                                barraProgreso.style.transition = `width ${tiempoRestante}ms linear`;
                                barraProgreso.style.width = '0%';
                            }
                            
                            iniciarTemporizador();
                        } else {
                            cerrarMensaje(mensaje);
                        }
                        
                        inicioPausa = null;
                    }
                }
                
                // Función para cerrar mensaje
                function cerrarMensaje(elemento) {
                    clearTimeout(temporizador);
                    elemento.classList.add('opacity-0', 'translate-x-2');
                    
                    setTimeout(() => {
                        if (elemento.parentNode) {
                            elemento.remove();
                            
                            // Si no quedan mensajes, eliminar el contenedor
                            const contenedor = document.getElementById('mensajes-container');
                            if (contenedor && contenedor.children.length === 0) {
                                contenedor.style.display = 'none';
                            }
                        }
                    }, 500);
                }
                
                // Iniciar animación de la barra de progreso
                if (barraProgreso) {
                    setTimeout(() => {
                        barraProgreso.style.width = '0%';
                    }, 100);
                }
                
                // Iniciar el temporizador
                iniciarTemporizador();
                
                // Evento para cerrar manualmente
                if (botonCerrar) {
                    botonCerrar.addEventListener('click', () => cerrarMensaje(mensaje));
                }
                
                // Eventos hover para pausar/reanudar
                mensaje.addEventListener('mouseenter', pausarTemporizador);
                mensaje.addEventListener('mouseleave', reanudarTemporizador);
            });
        });