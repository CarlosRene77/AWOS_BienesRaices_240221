extends ../layout/index

block contenido
    div.min-h-screen.bg-white.flex.items-center.justify-center.p-4
        div.max-w-md.w-full
            //- Logo y título
            div.text-center.mb-10
                div.inline-block.p-4.bg-gradient-to-r.from-indigo-50.to-purple-50.rounded-2xl.mb-6
                    svg.h-12.w-12.text-indigo-600.mx-auto(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z")
                h1.text-4xl.font-bold.text-gray-900 Bienes
                    span.font-light.text-indigo-600  Raíces
                h2.text-gray-500.mt-3.text-lg Recupera tu acceso

            //- Tarjeta principal
            div.bg-white.rounded-2xl.shadow-xl.p-8.border.border-gray-100
                //- Mensaje de ayuda
                div.bg-indigo-50.rounded-xl.p-4.mb-6.border.border-indigo-100
                    p.text-sm.text-indigo-800
                        | Escribe tu correo electrónico para enviarte las instrucciones de recuperación

                form.space-y-6
                    //- Campo email
                    div
                        label.block.text-sm.font-medium.text-gray-700.mb-2(for="correoUsuario") Correo electrónico
                        div.relative
                            span.absolute.inset-y-0.left-0.pl-3.flex.items-center.text-gray-400
                                svg.h-5.w-5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207")
                            input#correoUsuario.w-full.pl-10.pr-4.py-3.border.border-gray-200.rounded-xl(class="focus:border-indigo-300 focus:ring-4 focus:ring-indigo-50 focus:outline-none transition-all" placeholder="tu@email.com" name="correoUsuario" type="email")

                    //- Botón submit
                    button.w-full.bg-gradient-to-r.from-indigo-600.to-purple-600.text-white.font-semibold.py-3.px-4.rounded-xl.transition-all.duration-200(class="hover:from-indigo-700 hover:to-purple-700 hover:shadow-lg hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" type="submit")
                        | Enviar Instrucciones
                    
                    //- Separador
                    div.relative.my-6
                        div.absolute.inset-0.flex.items-center
                            div.w-full.border-t.border-gray-200
                        div.relative.flex.justify-center.text-sm
                            span.px-4.bg-white.text-gray-400 Opciones
                    
                    //- Links
                    div.grid.grid-cols-1.gap-3
                        a.flex.items-center.justify-center.gap-2.text-gray-600.bg-gray-50.py-3.px-4.rounded-xl.font-medium.border.border-gray-200(class="hover:bg-gray-100 hover:border-gray-300 transition-all" href="/auth/login")
                            svg.h-4.w-4(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12")
                            | Volver al inicio de sesión
                        
                        a.flex.items-center.justify-center.gap-2.text-gray-600.bg-gray-50.py-3.px-4.rounded-xl.font-medium.border.border-gray-200(class="hover:bg-gray-100 hover:border-gray-300 transition-all" href="/auth/registro")
                            svg.h-4.w-4(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                                path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z")
                            | Crear una cuenta nueva