extends ../layout/index

block contenido
    div.min-h-screen.bg-gray-50.flex.items-center.justify-center.p-4
        div.max-w-md.w-full
            div.text-center.mb-8
                div.inline-block.p-3.bg-indigo-100.rounded-full.mb-4
                    svg.h-8.w-8.text-indigo-600.mx-auto(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z")
                h1.text-3xl.font-bold.text-gray-900 Bienes
                    span.font-light.text-indigo-600  Raíces
                h2.text-gray-500.mt-2.text-base Recupera tu acceso

            div.bg-white.rounded-lg.shadow-lg.p-6.border.border-gray-100
                div.bg-indigo-50.rounded-lg.p-3.mb-4.border.border-indigo-100
                    p.text-sm.text-indigo-700
                        | Escribe tu correo para recibir instrucciones de recuperación

                form.space-y-4
                    div
                        label.block.text-sm.font-medium.text-gray-700.mb-1(for="correoUsuario") Correo electrónico
                        input#correoUsuario.w-full.px-3.py-2.border.border-gray-300.rounded-lg(class="focus:outline-none focus:ring-2 focus:ring-indigo-300" placeholder="tu@email.com" name="correoUsuario" type="email")

                    button.w-full.bg-indigo-600.text-white.py-2.px-4.rounded-lg.font-medium(class="hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" type="submit")
                        | Enviar Instrucciones
                
                div.flex.flex-col.gap-2.mt-4.pt-3.border-t.border-gray-200
                    a.flex.items-center.justify-center.gap-1.text-sm.text-gray-600.bg-gray-100.py-2.px-4.rounded-lg(class="hover:bg-gray-200" href="/auth/login")
                        svg.h-4.w-4(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12")
                        | Volver al inicio de sesión
                    
                    a.flex.items-center.justify-center.gap-1.text-sm.text-gray-600.bg-gray-100.py-2.px-4.rounded-lg(class="hover:bg-gray-200" href="/auth/registro")
                        svg.h-4.w-4(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z")
                        | Crear una cuenta nueva