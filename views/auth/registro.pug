extends ../layout/index
    
block contenido
    div.min-h-screen.bg-white.flex.items-center.justify-center.p-4
        div.max-w-2xl.w-full
            //- Logo y título
            div.text-center.mb-10
                div.inline-block.p-4.bg-gradient-to-r.from-indigo-50.to-purple-50.rounded-2xl.mb-6
                    svg.h-12.w-12.text-indigo-600.mx-auto(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z")
                h1.text-4xl.font-bold.text-gray-900 Bienes
                    span.font-light.text-indigo-600  Raíces
                p.text-gray-500.mt-3.text-lg Completa tus datos para registrarte

            //- Tarjeta principal
            div.bg-white.rounded-2xl.shadow-xl.p-8.border.border-gray-100
                form.space-y-6
                    //- Grid de 2 columnas
                    div.grid.grid-cols-1.gap-6(class="md:grid-cols-2")
                        //- Nombre completo
                        div
                            label.block.text-sm.font-medium.text-gray-700.mb-2(for="nombreUsuario") Nombre completo
                            div.relative
                                span.absolute.inset-y-0.left-0.pl-3.flex.items-center.text-gray-400
                                    svg.h-5.w-5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z")
                                input#nombreUsuario.w-full.pl-10.pr-4.py-3.border.border-gray-200.rounded-xl(class="focus:border-indigo-300 focus:ring-4 focus:ring-indigo-50 focus:outline-none transition-all" placeholder="Carlos Rene Morales" name="nombreUsuario" type="text")
                        
                        //- Email
                        div
                            label.block.text-sm.font-medium.text-gray-700.mb-2(for="correoUsuario") Correo electrónico
                            div.relative
                                span.absolute.inset-y-0.left-0.pl-3.flex.items-center.text-gray-400
                                    svg.h-5.w-5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207")
                                input#correoUsuario.w-full.pl-10.pr-4.py-3.border.border-gray-200.rounded-xl(class="focus:border-indigo-300 focus:ring-4 focus:ring-indigo-50 focus:outline-none transition-all" placeholder="usuario@gmail.com" name="correoUsuario" type="email")
                        
                        //- Contraseña
                        div
                            label.block.text-sm.font-medium.text-gray-700.mb-2(for="passwordUsuario") Contraseña
                            div.relative
                                span.absolute.inset-y-0.left-0.pl-3.flex.items-center.text-gray-400
                                    svg.h-5.w-5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z")
                                input#passwordUsuario.w-full.pl-10.pr-4.py-3.border.border-gray-200.rounded-xl(class="focus:border-indigo-300 focus:ring-4 focus:ring-indigo-50 focus:outline-none transition-all" placeholder="Mínimo 8 caracteres" name="passwordUsuario" type="password")
                        
                        //- Confirmar contraseña
                        div
                            label.block.text-sm.font-medium.text-gray-700.mb-2(for="confirmarContraseña") Confirmar contraseña
                            div.relative
                                span.absolute.inset-y-0.left-0.pl-3.flex.items-center.text-gray-400
                                    svg.h-5.w-5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z")
                                input#confirmacionPass.w-full.pl-10.pr-4.py-3.border.border-gray-200.rounded-xl(class="focus:border-indigo-300 focus:ring-4 focus:ring-indigo-50 focus:outline-none transition-all" placeholder="Repite tu contraseña" name="confirmacionPass" type="password")
                    
                    //- Términos y condiciones
                    div.flex.items-start.gap-3.mt-2
                        input#terminos(type="checkbox" class="mt-1.w-4.h-4.text-indigo-600.border-gray-300.rounded-md.focus:ring-indigo-500")
                        label.text-sm.text-gray-600(for="terminos")
                            | Acepto los 
                            a.text-indigo-600.font-medium(class="hover:text-indigo-700" href="/terminos") Términos y condiciones
                            |  y la 
                            a.text-indigo-600.font-medium(class="hover:text-indigo-700" href="/privacidad") Política de privacidad

                    //- Botón submit
                    button.w-full.bg-gradient-to-r.from-indigo-600.to-purple-600.text-white.font-semibold.py-3.px-4.rounded-xl.transition-all.duration-200(class="hover:from-indigo-700 hover:to-purple-700 hover:shadow-lg hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" type="submit")
                        | Registrar Usuario
                    
                    //- Separador
                    div.relative.my-6
                        div.absolute.inset-0.flex.items-center
                            div.w-full.border-t.border-gray-200
                        div.relative.flex.justify-center.text-sm
                            span.px-4.bg-white.text-gray-400 ¿Ya tienes una cuenta?
                    
                    //- Links
                    div.flex.items-center.justify-center.gap-4
                        a.text-center.text-gray-600.bg-gray-50.py-3.px-4.rounded-xl.font-medium.border.border-gray-200(class="hover:bg-gray-100 hover:border-gray-300 transition-all flex-1" href="/auth/login")
                            | Iniciar Sesión
                        a.text-center.text-gray-600.bg-gray-50.py-3.px-4.rounded-xl.font-medium.border.border-gray-200(class="hover:bg-gray-100 hover:border-gray-300 transition-all flex-1" href="/auth/recuperacionPassword")
                            | Recuperar Contraseña