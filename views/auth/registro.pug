extends ../layout/index
    
block contenido
    div.min-h-screen.bg-gray-50.flex.items-center.justify-center.p-4
        div.max-w-2xl.w-full
            div.text-center.mb-8
                div.inline-block.p-3.bg-indigo-100.rounded-full.mb-4
                    svg.h-8.w-8.text-indigo-600.mx-auto(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z")
                h1.text-3xl.font-bold.text-gray-900 Bienes
                    span.font-light.text-indigo-600  Raíces
                p.text-gray-500.mt-2.text-base Completa tus datos para registrarte

                if errores
                    .max-w-md.mx-auto.my-10
                        each error in errores
                            p.bg-red-600.text-white.uppercase.text-xs.text-center.p-2.mb-1.font-bold= error.msg

            div.bg-white.rounded-lg.shadow-lg.p-6.border.border-gray-100
                form.space-y-5(method="POST" action="/auth/registro" noValidate)
                    input(type="hidden" name="_csrf" value=csrfToken)
                    div.grid.grid-cols-1.gap-5(class="md:grid-cols-2")
                        div
                            label.block.text-sm.font-medium.text-gray-700.mb-1(for="nombreUsuario") Nombre completo
                            input#nombreUsuario.w-full.px-3.py-2.border.border-gray-300.rounded-lg(
                                class="focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                placeholder="Carlos Rene Morales"
                                name="nombreUsuario"
                                value=usuario ? usuario.nombreUsuario : ''
                                type="text"
                            )
                        
                        div
                            label.block.text-sm.font-medium.text-gray-700.mb-1(for="emailUsuario") Correo electrónico
                            input#emailUsuario.w-full.px-3.py-2.border.border-gray-300.rounded-lg(
                                class="focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                placeholder="usuario@gmail.com"
                                name="emailUsuario"
                                value=usuario ? usuario.emailUsuario : ''
                                type="email"
                            )
                        
                        // CONTRASEÑA CON OJO
                        div.relative
                            label.block.text-sm.font-medium.text-gray-700.mb-1(for="passwordUsuario") Contraseña
                            input#passwordUsuario.w-full.px-3.py-2.pr-10.border.border-gray-300.rounded-lg(
                                class="focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                placeholder="Mínimo 8 caracteres"
                                name="passwordUsuario"
                                type="password"
                            )
                            button#togglePassword(type="button" class="absolute right-3 top-9 text-gray-500 hover:text-indigo-600 transition duration-200")
                                svg#eyeIcon.w-5.h-5(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                                    // OJO NORMAL
                                    path#eyeOpen(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z")
                                    path#eyeOpen2(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z")
                                    // LINEA PROHIBIDO (oculta al inicio)
                                    line#eyeSlash(x1="4" y1="4" x2="20" y2="20" stroke-width="2" class="hidden")

                        div
                            label.block.text-sm.font-medium.text-gray-700.mb-1(for="confirmacionPass") Confirmar contraseña
                            input#confirmacionPass.w-full.px-3.py-2.border.border-gray-300.rounded-lg(
                                class="focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                placeholder="Repite tu contraseña"
                                name="confirmacionUsuario"
                                type="password"
                            )

                    div.flex.items-start.gap-2.mt-2
                        input#terminos(type="checkbox" class="mt-1 w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500")
                        label.text-xs.text-gray-600(for="terminos")
                            | Acepto los 
                            a.text-indigo-600(class="hover:underline" href="/terminos") Términos y condiciones
                            |  y la 
                            a.text-indigo-600(class="hover:underline" href="/privacidad") Política de privacidad

                    button.w-full.bg-indigo-600.text-white.py-2.px-4.rounded-lg.font-medium(
                        class="hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
                        type="submit"
                    )
                        | Registrar Usuario
                    
                    div.flex.items-center.justify-center.gap-4.pt-2.text-sm
                        a.text-gray-500(class="hover:text-indigo-600" href="/auth/login") Iniciar Sesión
                        span.text-gray-300 •
                        a.text-gray-500(class="hover:text-indigo-600" href="/auth/recuperacionPassword") Recuperar Contraseña

    // SCRIPT DEL OJO
    script.
        const toggle = document.getElementById('togglePassword');
        const password = document.getElementById('passwordUsuario');
        const slash = document.getElementById('eyeSlash');

        toggle.addEventListener('click', () => {
            if (password.type === 'password') {
                password.type = 'text';
                slash.classList.remove('hidden');
                slash.classList.add('animate-pulse');
            } else {
                password.type = 'password';
                slash.classList.add('hidden');
                slash.classList.remove('animate-pulse');
            }
        }); 