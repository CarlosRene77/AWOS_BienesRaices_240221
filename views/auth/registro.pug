extends ../layout/index
    
block contenido
    div.min-h-screen.bg-gray-50.flex.items-center.justify-center.p-4
        div.max-w-2xl.w-full
            div.text-center.mb-8
                div.inline-block.p-3.bg-indigo-100.rounded-full.mb-4
                    svg.h-8.w-8.text-indigo-600.mx-auto(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z")
                h1.text-3xl.font-bold.text-gray-900 Bienes
                    span.font-light.text-indigo-600  Raíces
                p.text-gray-500.mt-2.text-base Completa tus datos para registrarte

                // CONTENEDOR DE MENSAJES CON TEMPORIZADOR
                if errores
                    #mensajes-container.max-w-md.mx-auto.my-6.space-y-2
                        each error in errores
                            .mensaje-error.relative.bg-red-50.border-l-4.border-red-500.text-red-700.p-4.rounded-r-lg.shadow-md.transform.transition-all.duration-500(class="hover:shadow-lg" role="alert" data-duracion="5000")
                                .flex.items-center
                                    .flex-shrink-0
                                        svg.h-5.w-5.text-red-500(fill="currentColor" viewBox="0 0 20 20")
                                            path(fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd")
                                    .ml-3.flex-1
                                        p.text-sm.font-medium= error.msg
                                    .flex-shrink-0.ml-2
                                        button.cerrar-mensaje.text-red-500(class="hover:text-red-700 transition-colors duration-200")
                                            svg.h-4.w-4(fill="currentColor" viewBox="0 0 20 20")
                                                path(fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd")
                                // Barra de progreso
                                .barra-progreso.absolute.bottom-0.left-0.h-1.bg-red-500.rounded-b-lg(style="width: 100%; transition: width 5s linear;")

            div.bg-white.rounded-lg.shadow-lg.p-6.border.border-gray-100
                form.space-y-5(method="POST" action="/auth/registro" noValidate)
                    input(type="hidden" name="_csrf" value=csrfToken)
                    div.grid.grid-cols-1.gap-5(class="md:grid-cols-2")
                        div
                            label.block.text-sm.font-medium.text-gray-700.mb-1(for="nombreUsuario") Nombre completo
                            input#nombreUsuario.w-full.px-3.py-2.border.border-gray-300.rounded-lg(
                                class="focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-500 transition-all duration-200"
                                placeholder="Carlos Rene Morales"
                                name="nombreUsuario"
                                value=usuario ? usuario.nombreUsuario : ''
                                type="text"
                            )
                        
                        div
                            label.block.text-sm.font-medium.text-gray-700.mb-1(for="emailUsuario") Correo electrónico
                            input#emailUsuario.w-full.px-3.py-2.border.border-gray-300.rounded-lg(
                                class="focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-500 transition-all duration-200"
                                placeholder="usuario@gmail.com"
                                name="emailUsuario"
                                value=usuario ? usuario.emailUsuario : ''
                                type="email"
                            )
                        
                        // CONTRASEÑA CON OJO (estilo login)
                        div
                            label.block.text-sm.font-medium.text-gray-700.mb-1(for="passwordUsuario") Contraseña
                            div.relative
                                input#passwordUsuario(
                                    type="password"
                                    name="passwordUsuario"
                                    placeholder="Mínimo 8 caracteres"
                                    class="w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-transparent"
                                )
                                button(
                                    type="button"
                                    onclick="togglePassword('passwordUsuario')"
                                    class="absolute inset-y-0 right-0 flex items-center pr-3 focus:outline-none"
                                    aria-label="Mostrar u ocultar contraseña"
                                )
                                    svg.eye-icon(
                                        class="h-5 w-5 text-gray-400 transition-all duration-300"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        data-target="passwordUsuario"
                                    )
                                        path(
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                                        )
                                        path(
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                                        )
                                        line.eye-slash(
                                            x1="3"
                                            y1="3"
                                            x2="21"
                                            y2="21"
                                            stroke-width="2"
                                            class="opacity-0 translate-x-2 transition-all duration-300"
                                        )

                        // CONFIRMAR CONTRASEÑA CON OJO (estilo login)
                        div
                            label.block.text-sm.font-medium.text-gray-700.mb-1(for="confirmacionPass") Confirmar contraseña
                            div.relative
                                input#confirmacionPass(
                                    type="password"
                                    name="confirmacionUsuario"
                                    placeholder="Repite tu contraseña"
                                    class="w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-transparent"
                                )
                                button(
                                    type="button"
                                    onclick="togglePassword('confirmacionPass')"
                                    class="absolute inset-y-0 right-0 flex items-center pr-3 focus:outline-none"
                                    aria-label="Mostrar u ocultar contraseña"
                                )
                                    svg.eye-icon(
                                        class="h-5 w-5 text-gray-400 transition-all duration-300"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        data-target="confirmacionPass"
                                    )
                                        path(
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                                        )
                                        path(
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                                        )
                                        line.eye-slash(
                                            x1="3"
                                            y1="3"
                                            x2="21"
                                            y2="21"
                                            stroke-width="2"
                                            class="opacity-0 translate-x-2 transition-all duration-300"
                                        )

                    div.flex.items-start.gap-2.mt-2
                        input#terminos.mt-1.w-4.h-4.text-indigo-600.border-gray-300.rounded(class="focus:ring-indigo-500" type="checkbox")
                        label.text-xs.text-gray-600(for="terminos")
                            | Acepto los 
                            a.text-indigo-600(class="hover:underline hover:text-indigo-800 transition-colors duration-200" href="/terminos") Términos y condiciones
                            |  y la 
                            a.text-indigo-600(class="hover:underline hover:text-indigo-800 transition-colors duration-200" href="/privacidad") Política de privacidad

                    button.w-full.bg-indigo-600.text-white.py-2.px-4.rounded-lg.font-medium.transition-all.duration-200(
                        class="hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 active:bg-indigo-800"
                        type="submit"
                    )
                        | Registrar Usuario
                    
                    div.flex.items-center.justify-center.gap-4.pt-2.text-sm
                        a.text-gray-500(class="hover:text-indigo-600 transition-colors duration-200" href="/auth/login") Iniciar Sesión
                        span.text-gray-300 •
                        a.text-gray-500(class="hover:text-indigo-600 transition-colors duration-200" href="/auth/recuperacionPassword") Recuperar Contraseña

    // SCRIPT MEJORADO
    script.
        // Función para manejar los mensajes con temporizador
        function inicializarMensajes() {
            const mensajes = document.querySelectorAll('.mensaje-error');
            
            mensajes.forEach(mensaje => {
                const duracion = parseInt(mensaje.dataset.duracion) || 5000;
                const barraProgreso = mensaje.querySelector('.barra-progreso');
                const botonCerrar = mensaje.querySelector('.cerrar-mensaje');
                
                let temporizador;
                let tiempoRestante = duracion;
                let inicioPausa;
                
                function iniciarTemporizador() {
                    temporizador = setTimeout(() => {
                        cerrarMensaje(mensaje);
                    }, tiempoRestante);
                }
                
                function pausarTemporizador() {
                    clearTimeout(temporizador);
                    inicioPausa = Date.now();
                    
                    if (barraProgreso) {
                        const anchoActual = window.getComputedStyle(barraProgreso).width;
                        barraProgreso.style.transition = 'none';
                        barraProgreso.style.width = anchoActual;
                    }
                }
                
                function reanudarTemporizador() {
                    if (inicioPausa) {
                        const tiempoTranscurrido = Date.now() - inicioPausa;
                        tiempoRestante = Math.max(0, tiempoRestante - tiempoTranscurrido);
                        
                        if (tiempoRestante > 0) {
                            if (barraProgreso) {
                                barraProgreso.style.transition = `width ${tiempoRestante}ms linear`;
                                barraProgreso.style.width = '0%';
                            }
                            iniciarTemporizador();
                        } else {
                            cerrarMensaje(mensaje);
                        }
                        inicioPausa = null;
                    }
                }
                
                function cerrarMensaje(elemento) {
                    clearTimeout(temporizador);
                    elemento.classList.add('opacity-0', 'translate-x-2');
                    
                    setTimeout(() => {
                        if (elemento.parentNode) {
                            elemento.remove();
                            const contenedor = document.getElementById('mensajes-container');
                            if (contenedor && contenedor.children.length === 0) {
                                contenedor.style.display = 'none';
                            }
                        }
                    }, 500);
                }
                
                if (barraProgreso) {
                    setTimeout(() => {
                        barraProgreso.style.width = '0%';
                    }, 100);
                }
                
                iniciarTemporizador();
                
                if (botonCerrar) {
                    botonCerrar.addEventListener('click', () => cerrarMensaje(mensaje));
                }
                
                mensaje.addEventListener('mouseenter', pausarTemporizador);
                mensaje.addEventListener('mouseleave', reanudarTemporizador);
            });
        }

        // Función para toggle de contraseña (mismo estilo que login)
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const button = input.nextElementSibling;
            const eyeSlash = button.querySelector('.eye-slash');
            
            if (input.type === 'password') {
                input.type = 'text';
                eyeSlash.classList.remove('opacity-0', 'translate-x-2');
                eyeSlash.classList.add('opacity-100', 'translate-x-0');
            } else {
                input.type = 'password';
                eyeSlash.classList.remove('opacity-100', 'translate-x-0');
                eyeSlash.classList.add('opacity-0', 'translate-x-2');
            }
        }

        // Inicializar cuando el DOM esté listo
        document.addEventListener('DOMContentLoaded', () => {
            inicializarMensajes();
        });