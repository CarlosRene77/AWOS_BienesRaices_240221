extends ../layout/index

block contenido
    div.min-h-screen.bg-gray-50.flex.items-center.justify-center.p-4
        div.max-w-md.w-full
            div.text-center.mb-8
                div.inline-block.p-3.bg-indigo-100.rounded-full.mb-4
                    svg.h-8.w-8.text-indigo-600.mx-auto(fill="none" stroke="currentColor" viewBox="0 0 24 24")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z")
                h1.text-3xl.font-bold.text-gray-900 Completa tu 
                    span.font-light.text-indigo-600 registro
                p.text-gray-500.mt-2.text-base Solo falta crear tu contraseña

            // Mostrar información de la red social
            if usuarioTemp
                div.bg-gray-50.rounded-lg.p-4.mb-6.text-center
                    if usuarioTemp.avatar
                        img(src=usuarioTemp.avatar class="w-16 h-16 rounded-full mx-auto mb-3 border-2 border-indigo-200")
                    p.font-medium.text-gray-800 #{usuarioTemp.name}
                    p.text-sm.text-gray-500 #{usuarioTemp.email}
                    p.text-xs.text-indigo-600.mt-1 Registro con #{usuarioTemp.provider === 'facebook' ? 'Facebook' : 'Google'}

            // Mensajes de error
            if errores
                div#mensajes-container.mb-4.space-y-2
                    each error in errores
                        div.bg-red-50.border-l-4.border-red-500.text-red-700.p-3.rounded-r-lg.text-sm
                            p= error.msg

            div.bg-white.rounded-lg.shadow-lg.p-6.border.border-gray-100
                form(method="POST" action="/auth/completar-registro-social" noValidate)
                    input(type="hidden" name="_csrf" value=csrfToken)

                    // Contraseña
                    div.mb-4
                        label.block.text-sm.font-medium.text-gray-700.mb-1(for="password") Contraseña
                        div.relative
                            input#password(
                                type="password"
                                name="password"
                                placeholder="Mínimo 8 caracteres"
                                class="w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-transparent"
                                required
                            )
                            button(
                                type="button"
                                onclick="togglePassword('password')"
                                class="absolute inset-y-0 right-0 flex items-center pr-3 focus:outline-none"
                            )
                                svg.eye-icon(
                                    class="h-5 w-5 text-gray-400"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                )
                                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z")
                                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z")
                                    line.eye-slash(x1="3" y1="3" x2="21" y2="21" stroke-width="2" class="opacity-0 translate-x-2 transition-all duration-300")

                    // Confirmar contraseña
                    div.mb-6
                        label.block.text-sm.font-medium.text-gray-700.mb-1(for="confirmPassword") Confirmar contraseña
                        div.relative
                            input#confirmPassword(
                                type="password"
                                name="confirmPassword"
                                placeholder="Repite tu contraseña"
                                class="w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-transparent"
                                required
                            )
                            button(
                                type="button"
                                onclick="togglePassword('confirmPassword')"
                                class="absolute inset-y-0 right-0 flex items-center pr-3 focus:outline-none"
                            )
                                svg.eye-icon(
                                    class="h-5 w-5 text-gray-400"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                )
                                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z")
                                    path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z")
                                    line.eye-slash(x1="3" y1="3" x2="21" y2="21" stroke-width="2" class="opacity-0 translate-x-2 transition-all duration-300")

                    button.w-full.bg-indigo-600.text-white.py-2.px-4.rounded-lg.font-medium(
                        class="hover:bg-indigo-700 transition"
                        type="submit"
                    )
                        | Crear cuenta y continuar

                    div.text-center.mt-4
                        a.text-sm.text-gray-500(class="hover:text-indigo-600" href="/auth/login") ← Volver al inicio de sesión

    script.
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const button = input.nextElementSibling;
            const eyeSlash = button.querySelector('.eye-slash');
            
            if (input.type === 'password') {
                input.type = 'text';
                eyeSlash.classList.remove('opacity-0', 'translate-x-2');
                eyeSlash.classList.add('opacity-100', 'translate-x-0');
            } else {
                input.type = 'password';
                eyeSlash.classList.remove('opacity-100', 'translate-x-0');
                eyeSlash.classList.add('opacity-0', 'translate-x-2');
            }
        }